# Claude API key from https://console.anthropic.com/
# For "extract brand from images" the key must have Vision (image) access enabled.
ANTHROPIC_API_KEY=your_api_key_here

# Claude model: claude-sonnet-4-20250514 (default) или claude-opus-4-6 (лучшее качество)
# ANTHROPIC_MODEL=claude-opus-4-6

# OpenAI API key from https://platform.openai.com/api-keys (for ChatGPT)
OPENAI_API_KEY=your_openai_key_here

# OpenAI model: gpt-5-nano (default)
# OPENAI_MODEL=gpt-5-nano

# Which API to use: anthropic (Claude) or openai (ChatGPT). Default: anthropic
API_PROVIDER=anthropic

# Optional: port for the server (default 3000)
PORT=3000
